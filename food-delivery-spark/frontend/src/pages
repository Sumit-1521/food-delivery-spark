import React, { useState } from 'react';
import { fetchPrediction } from '../services/apiService';

const MainPage = () => {
    const [formData, setFormData] = useState({
        distance: '',
        weather: '',
        traffic: '',
        timeOfDay: '',
        vehicleType: '',
        preparationTime: '',
        courierExperience: ''
    });
    const [prediction, setPrediction] = useState(null);
    const [loading, setLoading] = useState(false);
    const [error, setError] = useState('');

    const handleChange = (e) => {
        const { name, value } = e.target;
        setFormData({ ...formData, [name]: value });
    };

    const handleSubmit = async (e) => {
        e.preventDefault();
        setLoading(true);
        setError('');
        try {
            const result = await fetchPrediction(formData);
            setPrediction(result);
        } catch (err) {
            setError('Error fetching prediction');
        } finally {
            setLoading(false);
        }
    };

    return (
        <div>
            <h1>Food Delivery Time Prediction</h1>
            <form onSubmit={handleSubmit}>
                <input type="number" name="distance" placeholder="Distance (km)" value={formData.distance} onChange={handleChange} required />
                <input type="text" name="weather" placeholder="Weather" value={formData.weather} onChange={handleChange} required />
                <input type="text" name="traffic" placeholder="Traffic Level" value={formData.traffic} onChange={handleChange} required />
                <input type="text" name="timeOfDay" placeholder="Time of Day" value={formData.timeOfDay} onChange={handleChange} required />
                <input type="text" name="vehicleType" placeholder="Vehicle Type" value={formData.vehicleType} onChange={handleChange} required />
                <input type="number" name="preparationTime" placeholder="Preparation Time (min)" value={formData.preparationTime} onChange={handleChange} required />
                <input type="number" name="courierExperience" placeholder="Courier Experience (yrs)" value={formData.courierExperience} onChange={handleChange} required />
                <button type="submit" disabled={loading}>Predict</button>
            </form>
            {loading && <p>Loading...</p>}
            {error && <p>{error}</p>}
            {prediction && <h2>Predicted Delivery Time: {prediction} minutes</h2>}
        </div>
    );
};

export default MainPage;